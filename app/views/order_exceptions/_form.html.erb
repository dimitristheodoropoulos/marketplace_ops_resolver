<%= form_with(model: order_exception) do |form| %>
  <% if order_exception.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(order_exception.errors.count, "error") %> prohibited this order_exception from being saved:</h2>

      <ul>
        <% order_exception.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :order_number, style: "display: block" %>
    <%= form.text_field :order_number %>
  </div>

  <div>
    <%= form.label :merchant_id, style: "display: block" %>
    <%= form.number_field :merchant_id %>
  </div>

  <div>
    <%= form.label :status, style: "display: block" %>
    <%= form.text_field :status %>
  </div>

  <div>
    <%= form.label :error_message, style: "display: block" %>
    <%= form.textarea :error_message %>
  </div>

  <div>
    <%= form.label :resolved_at, style: "display: block" %>
    <%= form.datetime_field :resolved_at %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
